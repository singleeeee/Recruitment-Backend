# ============================================================
# 生产环境变量模板（Railway 部署时在平台 Variables 面板填写）
# ============================================================

# 数据库（Railway 会自动注入 DATABASE_URL，无需手动填写）
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/railway

# Redis（Railway Redis 插件会自动注入 REDIS_URL，无需手动填写）
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# JWT
JWT_SECRET=your-strong-random-secret-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-strong-random-refresh-secret-here
JWT_REFRESH_EXPIRES_IN=7d

# 服务端口（Railway 会自动设置 PORT，无需手动填写）
PORT=3001

# 跨域（填写 Vercel 前端域名，如 https://your-app.vercel.app）
CORS_ORIGIN=https://your-app.vercel.app

# 文件上传目录
UPLOAD_DIR=uploads

# QQ 邮箱 SMTP（可选，不填则邮件通知功能不生效）
QQ_EMAIL_USER=your-qq@qq.com
QQ_EMAIL_AUTH_CODE=your-smtp-auth-code
EMAIL_SENDER_NAME=招新管理系统

# AI 评估（可选，不填则 AI 评估功能自动跳过，不影响其他功能）
# 公网可用的 OpenAI 兼容接口，如 https://api.deepseek.com/v1
OPENAI_BASE_URL=
OPENAI_API_KEY=
AI_MODEL=deepseek-chat
